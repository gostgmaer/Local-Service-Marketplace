# ─── Application ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
# --- Tenant configuration ---
# Enforce tenant scoping on every request.
# true  → x-tenant-id header is required (falls back to DEFAULT_TENANT_ID when set).
# false → tenant header is optional; service operates without multi-tenant isolation.
TENANCY_ENABLED=true
# Fallback tenant when x-tenant-id header is absent.
# For single-tenant: set to your slug. For strict enforcement: leave blank.
DEFAULT_TENANT_ID=your-tenant-slug


# ─── Authentication ────────────────────────────────────────────────
# Bearer token clients must send in Authorization header
API_KEY=change-me-to-a-strong-random-secret

# ─── MongoDB ───────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/sms-delivery-service

# ─── Redis (optional) ─────────────────────────────────────────────
# If set, rate limiter uses Redis for cross-instance tracking
# REDIS_URL=redis://localhost:6379

# ─── SMS Provider Selection ────────────────────────────────────────
# Tier 1 — Truly free, no CC ever:
#   mock | fast2sms | 2factor | smsgateway
# Tier 2 — Free credits, no CC:
#   infobip | telnyx | vonage | msg91 | d7networks
# Tier 3 — Free credits but CC required:
#   sinch | textlocal | gupshup | plivo | awssns
# Tier 4 — Enterprise / sales-only:
#   twilio | kaleyra | airteliq | jiocx | exotel | routemobile | valuefirst | smscountry
SMS_PROVIDER=mock

# Optional fallback if primary fails (leave blank to disable)
SMS_FALLBACK_PROVIDER=

# ─── OTP Settings ─────────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ─── Retry Settings ───────────────────────────────────────────────
SMS_MAX_RETRY_ATTEMPTS=3

# ─── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
SMS_RATE_LIMIT_WINDOW_MS=60000
SMS_RATE_LIMIT_MAX=50

# ─── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info
# LOG_FORMAT=pretty   # Use "pretty" for local dev; omit for JSON in production

# ─────────────────────────────────────────────────────────────────
# PROVIDER CREDENTIALS — Fill in only the provider you are using
# ─────────────────────────────────────────────────────────────────

# Mock (development / no credentials needed)
MOCK_SUCCESS_RATE=0.95

# Fast2SMS (free, no CC) — https://www.fast2sms.com/
FAST2SMS_API_KEY=

# 2Factor (free trial) — https://2factor.in/
TWOFACTOR_API_KEY=

# SMSGateway.me (free self-hosted) — https://smsgateway.me/
SMS_GATEWAY_USERNAME=
SMS_GATEWAY_PASSWORD=
SMS_GATEWAY_DEVICE_ID=

# Infobip (30-day trial ~$20 credit, no CC) — https://www.infobip.com/
INFOBIP_API_KEY=
INFOBIP_BASE_URL=

# Telnyx ($10 free credit, no CC) — https://telnyx.com/
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_WEBHOOK_SECRET=

# Vonage (€2 free, no CC) — https://www.vonage.com/
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_SIGNATURE_SECRET=

# MSG91 (₹50 free) — https://msg91.com/
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_WEBHOOK_SECRET=

# D7 Networks (free trial credits) — https://d7sms.com/
D7NETWORKS_API_KEY=

# Sinch ($10 free, CC required) — https://www.sinch.com/
SINCH_SERVICE_PLAN_ID=
SINCH_API_TOKEN=
SINCH_SENDER=

# TextLocal (India, free credits with CC) — https://www.textlocal.in/
TEXTLOCAL_API_KEY=
TEXTLOCAL_SENDER=

# Gupshup (free tier available) — https://www.gupshup.io/
GUPSHUP_API_KEY=
GUPSHUP_USER_ID=
GUPSHUP_SOURCE_MOBILE=

# Plivo (free trial $0.10 CC required) — https://www.plivo.com/
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_SENDER=

# AWS SNS (free tier 100 SMS/mo) — https://aws.amazon.com/sns/
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SNS_SMS_TYPE=Transactional

# Twilio (trial $15.50 CC required) — https://www.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_URL=

# Kaleyra (India, contact sales) — https://www.kaleyra.com/
KALEYRA_API_KEY=
KALEYRA_SID=
KALEYRA_SENDER=

# Airtel IQ (India, OAuth2) — https://www.airteliq.io/
AIRTELIQ_CLIENT_ID=
AIRTELIQ_CLIENT_SECRET=
AIRTELIQ_SENDER=

# JioCX (India, enterprise) — https://www.jiocx.com/
JIOCX_API_KEY=
JIOCX_ACCOUNT_ID=
JIOCX_SENDER=

# Exotel (India, trial) — https://exotel.com/
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_SENDER=

# Route Mobile (India, enterprise) — https://www.routemobile.com/
ROUTEMOBILE_USERNAME=
ROUTEMOBILE_PASSWORD=
ROUTEMOBILE_SOURCE=

# ValueFirst / Tanla (India, B2B) — https://www.tanlaplatforms.com/
VALUEFIRST_USERNAME=
VALUEFIRST_PASSWORD=
VALUEFIRST_SENDER=

# SMSCountry (India) — https://www.smscountry.com/
SMSCOUNTRY_USERNAME=
SMSCOUNTRY_PASSWORD=
SMSCOUNTRY_SENDER_ID=

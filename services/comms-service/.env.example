# ===============================================
# COMMS SERVICE CONFIGURATION (notification + messaging)
# ===============================================

# Application
NODE_ENV=development
PORT=3007
SERVICE_NAME=comms-service

# JWT Secret — MUST match identity-service JWT_SECRET exactly (used to verify socket auth tokens)
JWT_SECRET=your-jwt-secret-here

# Frontend URL — used for CORS and WebSocket gateway (must match browser origin)
FRONTEND_URL=http://localhost:3000

# Internal Gateway Secret — MUST match all other services' GATEWAY_INTERNAL_SECRET
GATEWAY_INTERNAL_SECRET=your-gateway-internal-secret-here

# Database - PostgreSQL
# Docker Compose: DATABASE_HOST=pgbouncer  (traffic is pooled via PgBouncer)
# Local dev (outside Docker): DATABASE_HOST=localhost
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=marketplace
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace
# Docker URL: postgresql://postgres:postgres_dev_only@pgbouncer:5432/marketplace

# Connection Pooling
# Kept low — PgBouncer (transaction mode) multiplexes to 25 actual backend connections
DB_POOL_MAX=10
DB_POOL_MIN=2

# SSL/TLS for PostgreSQL connection
# Set to true when connecting to managed cloud databases (AWS RDS, GCP Cloud SQL, etc.)
DATABASE_SSL=false

# Email Service Integration
# For Docker: http://email-service:3500
# For Local: http://localhost:4000 (mapped from 3500)
EMAIL_SERVICE_URL=http://localhost:4000
EMAIL_ENABLED=true

# SMS Service Integration
# For Docker: http://sms-service:3000
# For Local: http://localhost:5000 (mapped from 3000)
SMS_SERVICE_URL=http://localhost:5000
SMS_ENABLED=false
SMS_API_KEY=change-me-to-a-strong-random-secret

# Feature Flags — controlled via DB (system_settings table, admin panel at /admin/settings)
# comms-service reads feature flags directly from the shared PostgreSQL DB (system_settings table).
# No separate oversight-service URL needed — uses the existing DATABASE_URL connection.

# WhatsApp Configuration (only needed if whatsapp_enabled is set to true in admin panel)
# Provider: "meta" (Meta Cloud API) or "twilio" (Twilio WhatsApp)
WHATSAPP_PROVIDER=meta
WHATSAPP_ENABLED=false
# Meta Cloud API credentials:
META_WHATSAPP_TOKEN=your-meta-whatsapp-token
META_WHATSAPP_PHONE_ID=your-phone-number-id
# Twilio WhatsApp (alternative provider):
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=+1234567890

# Firebase Cloud Messaging (FCM) - For Push Notifications
# Enable FCM integration (set to true to use Firebase, false to mock push notifications)
FCM_ENABLED=true
# Firebase project credentials (get from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=development-4a638
FIREBASE_CLIENT_EMAIL=firebase-notification@development-4a638.iam.gserviceaccount.com
# Private key can be base64 encoded or raw JSON string (with \\n for newlines)
FIREBASE_PRIVATE_KEY=base64_encoded_private_key_or_raw_json_string
# Note: For production, use secrets manager instead of env vars

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=comms-service

# Feature Flags
CACHE_ENABLED=false
EVENT_BUS_ENABLED=false
WORKERS_ENABLED=false
WORKER_CONCURRENCY=5            # Number of concurrent jobs per worker processor

# Logging
LOG_LEVEL=info
FILE_UPLOAD_SERVICE_URL=http://localhost:4100
FILE_DEFAULT_TENANT_ID=local-service-marketplace
REQUEST_TIMEOUT_MS=72000

# ===============================================
# IDENTITY SERVICE CONFIGURATION (auth + user)
# ===============================================

# Application
NODE_ENV=development
PORT=3001
SERVICE_NAME=identity-service

# Database - PostgreSQL
# Docker Compose: DATABASE_HOST=pgbouncer  (traffic is pooled via PgBouncer)
# Local dev (outside Docker): DATABASE_HOST=localhost
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=marketplace
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace
# Docker URL: postgresql://postgres:postgres_dev_only@pgbouncer:5432/marketplace

# Connection Pooling
# Kept low — PgBouncer (transaction mode) multiplexes to 25 actual backend connections
DB_POOL_MAX=10
DB_POOL_MIN=2

# SSL/TLS for PostgreSQL connection
# Set to true when connecting to managed cloud databases (AWS RDS, GCP Cloud SQL, etc.)
DATABASE_SSL=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-in-production
JWT_REFRESH_EXPIRATION=90d
SESSION_TTL_DAYS=90

# Encryption Key - used for encrypting sensitive fields at rest
# Generate with: openssl rand -base64 64
ENCRYPTION_KEY=your-encryption-key-change-in-production-min-64-chars

# Session Secret - used for session management
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-change-in-production

# Gateway Internal Secret
GATEWAY_INTERNAL_SECRET=gateway-internal-secret-change-in-production

# Email verification
EMAIL_VERIFICATION_EXPIRES_IN=24h
PASSWORD_RESET_EXPIRES_IN=1h

# Rate Limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW=15m

# Pagination
DEFAULT_PAGE_LIMIT=20
MAX_PAGE_LIMIT=100

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3700/api/v1/user/auth/google/callback

# OAuth - Facebook
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3700/api/v1/user/auth/facebook/callback

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:3000

# Service Communication
# For Docker: http://comms-service:3007
# For Local: http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3007

# SMS/notifications are delivered via comms-service (NOTIFICATION_SERVICE_URL above).
# Identity-service does NOT need Twilio credentials — set them in comms-service.

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=identity-service

# Feature Flags
CACHE_ENABLED=false
EVENT_BUS_ENABLED=false
WORKERS_ENABLED=false           # Enable BullMQ background workers (requires Redis)
WORKER_CONCURRENCY=5            # Number of concurrent jobs per worker processor

# Logging
LOG_LEVEL=info
FILE_UPLOAD_SERVICE_URL=http://localhost:4100
DEFAULT_TENANT_ID=local-service-marketplace
REQUEST_TIMEOUT_MS=72000

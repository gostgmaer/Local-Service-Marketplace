# ===============================================
# EMAIL SERVICE - Environment Configuration
# Node.js Email Microservice
# ===============================================

# -----------------------------------------------
# Server Configuration
# -----------------------------------------------

NODE_ENV=development
PORT=3500
LOG_LEVEL=info
ENABLE_LOGGING=true       # Set to 'false' to completely disable logging (fastest)
DISABLE_CONSOLE_LOG=false # Set to 'true' to disable console output (keep file logs only)
ENABLE_FILE_LOGS=false    # Set to 'true' to enable file logging (recommended for production)

# Cluster Mode (multi-core)
ENABLE_CLUSTER=true
CLUSTER_WORKERS=0  # 0 = auto-detect CPU cores

# Server Timeouts
REQUEST_TIMEOUT_MS=30000
SERVER_TIMEOUT_MS=120000
SHUTDOWN_TIMEOUT_MS=10000

# Trust Proxy (set true behind load balancer)
TRUST_PROXY=false

# CORS
CORS_ORIGIN=*

# -----------------------------------------------
# MongoDB Configuration
# -----------------------------------------------

# MongoDB Connection URL
# For Docker: mongodb://emailadmin:emailpass123@mongo-email:27017/email_service?authSource=admin
# For Azure CosmosDB: mongodb+srv://username:password@cluster.mongocluster.cosmos.azure.com/?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000
MONGO_URL=mongodb://emailadmin:emailpass123@mongo-email:27017/email_service?authSource=admin

# Connection Pool Settings
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10
MONGO_WRITE_CONCERN=majority
MONGO_READ_PREFERENCE=primaryPreferred

# MongoDB Timeout Settings
DB_MAX_IDLE_TIME=30000                # Maximum time a connection can be idle (30 seconds)
DB_SERVER_SELECTION_TIMEOUT=5000      # Timeout for selecting a server (5 seconds)
DB_SOCKET_TIMEOUT=45000               # Socket timeout (45 seconds)
DB_CONNECT_TIMEOUT=10000              # Connection establishment timeout (10 seconds)
DB_HEARTBEAT=10000                    # Heartbeat interval (10 seconds)

# -----------------------------------------------
# Kafka Configuration (Event-Driven Architecture)
# -----------------------------------------------

ENABLE_KAFKA=false
KAFKA_BROKERS=kafka:29092
KAFKA_CLIENT_ID=email-service
KAFKA_GROUP_ID=email-service-consumer-group
KAFKA_TOPIC_SEND=email.notification.send
KAFKA_TOPIC_SUCCESS=email.notification.delivered
KAFKA_TOPIC_FAILED=email.notification.failed
KAFKA_CONCURRENT_PARTITIONS=3

# -----------------------------------------------
# Email Configuration
# -----------------------------------------------

# Default Sender
DEFAULT_FROM_EMAIL=noreply@marketplace.com
DEFAULT_FROM_NAME=Local Service Marketplace

# SMTP Provider Configuration
# Leave EMAIL_SERVICE blank to use custom SMTP (host/port/user/pass)
# Or set to: 'gmail', 'sendgrid', 'mailgun', etc.
EMAIL_SERVICE=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# OAuth2 Credentials (Optional - for Gmail API)
OAUTH2_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH2_CLIENT_SECRET=your-client-secret
OAUTH2_REFRESH_TOKEN=your-refresh-token
OAUTH2_REDIRECT_URI=https://developers.google.com/oauthplayground

# Application URLs (for email templates)
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
APPLICATION_NAME=Local Service Marketplace

# -----------------------------------------------
# Fallback Email Service Configuration
# -----------------------------------------------

# Fallback SMTP (used if primary fails)
FALLBACK_EMAIL_SERVICE=
FALLBACK_EMAIL_HOST=smtp.gmail.com
FALLBACK_EMAIL_PORT=587
FALLBACK_EMAIL_SECURE=false
FALLBACK_EMAIL_USER=fallback-email@example.com
FALLBACK_EMAIL_PASS=fallback-app-password

# -----------------------------------------------
# Advanced Email Settings
# -----------------------------------------------

# Connection Pool Settings
EMAIL_MAX_CONNECTIONS=20     # Max simultaneous SMTP connections
EMAIL_MAX_MESSAGES=500       # Messages per connection before reconnect

# Rate Limiting
EMAIL_RATE_LIMIT=50          # Max emails per rate delta period
EMAIL_RATE_DELTA=1000        # Rate limit period in ms (1 second)

# TLS/SSL Configuration
EMAIL_TLS_REJECT_UNAUTHORIZED=true
EMAIL_TLS_MIN_VERSION=TLSv1.2

# Debug & Retry
EMAIL_DEBUG=false
EMAIL_RETRY_LIMIT=3
EMAIL_RETRY_BACKOFF_MS=5000

# -----------------------------------------------
# Idempotency Configuration
# -----------------------------------------------

# Prevents duplicate emails within TTL window
IDEMPOTENCY_TTL_MS=3600000                  # 1 hour
IDEMPOTENCY_CLEANUP_INTERVAL_MS=300000      # 5 minutes

# -----------------------------------------------
# Security & Rate Limiting
# -----------------------------------------------

RATE_LIMIT_WINDOW_MS=900000      # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100      # 100 requests per window

# -----------------------------------------------
# Redis (Optional - for production)
# -----------------------------------------------

# Uncomment for production idempotency store
# REDIS_URL=redis://redis:6379
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=

# -----------------------------------------------
# Multi-Tenancy Configuration
# -----------------------------------------------

# TENANCY_ENABLED:
# true  → resolve tenant from x-tenant-id header (fallback to DEFAULT_TENANT_ID)
# false → ignore tenant resolution (single-tenant mode)
TENANCY_ENABLED=false

# Fallback tenant when x-tenant-id header is absent
# Leave blank to require the header explicitly
DEFAULT_TENANT_ID=marketplace

# -----------------------------------------------
# Additional Configuration
# -----------------------------------------------

# Enable synchronous email endpoint (for testing)
ENABLE_SYNC_ENDPOINT=false

# -----------------------------------------------
# NOTES
# -----------------------------------------------
# 
# 1. For Gmail: Use App Passwords (https://myaccount.google.com/apppasswords)
# 2. For production: Use dedicated email service (SendGrid, Mailgun, AWS SES)
# 3. MongoDB is required - start with: docker-compose --profile email up -d
# 4. Kafka is optional - only enable for event-driven architecture
# 
# For detailed setup guide, see:
# - docs/EMAIL_SMS_INTEGRATION_GUIDE.md
# - docs/ENVIRONMENT_VARIABLES_AUDIT_REPORT.md

NODE_ENV=development
PORT=3008

DATABASE_HOST=localhost
DATABASE_PORT=5439
DATABASE_NAME=notification_service_db
DATABASE_USER=notification_service_user
DATABASE_PASSWORD=notification_service_password

# Email Service Integration
EMAIL_SERVICE_URL=http://email-service:3000
EMAIL_ENABLED=true

# SMS Service Integration
SMS_SERVICE_URL=http://sms-service:3000
SMS_ENABLED=false
SMS_API_KEY=change-me-to-a-strong-random-secret

# Feature Flags - Disable for MVP Launch
IN_APP_NOTIFICATIONS_ENABLED=false
PUSH_NOTIFICATIONS_ENABLED=false
NOTIFICATION_PREFERENCES_ENABLED=false
DEVICE_TRACKING_ENABLED=false

# Infrastructure
CACHE_ENABLED=false
EVENT_BUS_ENABLED=false
WORKERS_ENABLED=false

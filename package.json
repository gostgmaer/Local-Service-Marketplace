{
  "name": "local-service-marketplace",
  "version": "1.0.0",
  "private": true,
  "description": "Microservices-based Local Service Marketplace",
  "scripts": {
    "install:all": "pnpm install",
    "build:all": "pnpm -r --filter './services/*' --filter './api-gateway' build",
    "start:dev": "pnpm -r --parallel --filter './services/*' --filter './api-gateway' start:dev"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {}
}

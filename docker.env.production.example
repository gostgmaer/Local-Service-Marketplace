# ==================================================
# Local Service Marketplace — Production Environment
# ==================================================
#
# HOW TO USE ON THE SERVER
# ─────────────────────────────────────────────────
# 1. Copy this file to docker.env in the app directory:
#      cp docker.env.production.example docker.env
#
# 2. Fill in every blank value (search for CHANGE_ME or empty =).
#    Auto-generate secrets:
#      JWT / session / gateway secrets:  openssl rand -base64 48
#      Encryption key (64 chars min):    openssl rand -base64 64
#      Redis password:                   openssl rand -base64 32
#      Postgres password:                openssl rand -base64 32
#
# 3. The deploy script reads ALL variables from this single file.
#    It will auto-generate JWT_SECRET / JWT_REFRESH_SECRET /
#    GATEWAY_INTERNAL_SECRET if left blank — but set them explicitly
#    so they are stable across redeploys.
#
# 4. DATABASE_URL must stay in sync with POSTGRES_PASSWORD.
#    Replace REPLACE_PASSWORD with the same value as POSTGRES_PASSWORD.
#
# FILES ON THE SERVER
# ─────────────────────────────────────────────────
#   ~/Local-Service-Marketplace/docker.env  ← this file (never committed)
#   ~/Local-Service-Marketplace/.env        ← same file, or a symlink
#   Both are preserved across deployments by the deploy script.
# ==================================================

# -----------------------------------------------
# RUNTIME
# -----------------------------------------------
NODE_ENV=production
COMPOSE_PROFILES=workers
TOKEN_VALIDATION_STRATEGY=local

# -----------------------------------------------
# SECURITY — REQUIRED (generate all before first deploy)
# -----------------------------------------------
# openssl rand -base64 48
JWT_SECRET=
JWT_REFRESH_SECRET=
GATEWAY_INTERNAL_SECRET=

# openssl rand -base64 64
ENCRYPTION_KEY=

# openssl rand -base64 32
SESSION_SECRET=
AUTH_SECRET=

# -----------------------------------------------
# BOOTSTRAP ADMIN USERS — REQUIRED
# -----------------------------------------------
# Created / updated on every deploy via bootstrap_required_users().
# Password must be >= 12 characters.
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_min12chars
SUPER_ADMIN_NAME=Super Admin

# Optional second admin — leave blank to skip
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# -----------------------------------------------
# POSTGRESQL — REQUIRED
# -----------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=marketplace

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME_strong_password
DATABASE_NAME=marketplace
# Keep in sync with DATABASE_PASSWORD above
DATABASE_URL=postgresql://postgres:REPLACE_PASSWORD@postgres:5432/marketplace
DATABASE_SSL=false

DB_POOL_MAX=20
DB_POOL_MIN=5

# -----------------------------------------------
# REDIS — REQUIRED
# -----------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_RATE_LIMIT_ENABLED=true

# -----------------------------------------------
# DOMAINS & CORS — REQUIRED
# -----------------------------------------------
# Your actual public domains (used by Traefik labels + CORS headers)
LSP_API_DOMAIN=lsp-api.yourdomain.com
LSP_FRONTEND_DOMAIN=lsp.yourdomain.com
DOMAIN_NAME=lsp.yourdomain.com

FRONTEND_URL=https://lsp.yourdomain.com
CORS_ORIGIN=https://lsp.yourdomain.com
CORS_ORIGINS=https://lsp.yourdomain.com

NEXT_PUBLIC_API_URL=https://lsp-api.yourdomain.com
INTERNAL_API_URL=http://api-gateway:3000
NEXTAUTH_URL=https://lsp.yourdomain.com

# -----------------------------------------------
# EXTERNAL SERVICES — REQUIRED
# -----------------------------------------------
# File upload service (must be a real https URL — deploy rejects placeholders)
FILE_UPLOAD_SERVICE_URL=https://your-file-upload-service.onrender.com
FILE_DEFAULT_TENANT_ID=default

# Notification service (unified email + SMS delivery)
NOTIFICATION_SERVICE_URL=https://your-notification-service.vercel.app
NOTIFICATION_API_KEY=CHANGE_ME_notification_api_key
NOTIFICATION_FROM_EMAIL=noreply@yourdomain.com
NOTIFICATION_FROM_NAME=Local Service Marketplace
DEFAULT_TENANT_ID=local-service-marketplace

# -----------------------------------------------
# INTERNAL SERVICE URLS (Docker network — do not change)
# -----------------------------------------------
IDENTITY_SERVICE_URL=http://identity-service:3001
MARKETPLACE_SERVICE_URL=http://marketplace-service:3003
PAYMENT_SERVICE_URL=http://payment-service:3006
COMMS_SERVICE_URL=http://comms-service:3007
OVERSIGHT_SERVICE_URL=http://oversight-service:3010

# -----------------------------------------------
# API GATEWAY
# -----------------------------------------------
API_GATEWAY_PORT=3700
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
REQUEST_TIMEOUT_MS=72000

# -----------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------
CACHE_ENABLED=true
WORKERS_ENABLED=true
WORKER_CONCURRENCY=10
EVENT_BUS_ENABLED=false
BACKGROUND_JOBS_ENABLED=false
RATE_LIMITING_ENABLED=true
FEATURE_FLAGS_ENABLED=true
ANALYTICS_ENABLED=false
INFRASTRUCTURE_ENABLED=false
MESSAGING_ENABLED=false
API_GATEWAY_ENABLED=true

EMAIL_ENABLED=true
SMS_ENABLED=false
IN_APP_NOTIFICATIONS_ENABLED=false
PUSH_NOTIFICATIONS_ENABLED=false
NOTIFICATION_PREFERENCES_ENABLED=false
DEVICE_TRACKING_ENABLED=false

# -----------------------------------------------
# PAYMENT
# -----------------------------------------------
# Options: mock | razorpay | stripe
PAYMENT_GATEWAY=mock
# Razorpay (if PAYMENT_GATEWAY=razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Stripe (if PAYMENT_GATEWAY=stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------
# OAUTH (optional)
# -----------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://lsp-api.yourdomain.com/api/v1/user/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://lsp-api.yourdomain.com/api/v1/user/auth/facebook/callback

# -----------------------------------------------
# KAFKA (optional — Level 4 only)
# -----------------------------------------------
KAFKA_BROKERS=kafka:29092
KAFKA_CLIENT_ID=marketplace-service
ZOOKEEPER_HOST=zookeeper
ZOOKEEPER_PORT=2181

# -----------------------------------------------
# APPLICATION
# -----------------------------------------------
APPLICATION_NAME=Local Service Marketplace
LOG_LEVEL=info
ENABLE_LOGGING=true
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=


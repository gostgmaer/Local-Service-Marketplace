# ==================================================
# Local Service Marketplace - Production (Worker)
# ==================================================
# Usage:
#   cp docker.env.production.example docker.env
#   edit docker.env with real values
#   ./scripts/deploy-production-worker.sh
#
# This template is for Level 3 worker deployment.
# It is compatible with scripts/deploy-production-worker.sh.

# -------------------------------
# Runtime / Compose
# -------------------------------
NODE_ENV=production
COMPOSE_PROFILES=workers
TOKEN_VALIDATION_STRATEGY=local

# -------------------------------
# Security (required)
# -------------------------------
# Generate with openssl rand -base64 48 (or 64 for encryption key)
JWT_SECRET=
JWT_REFRESH_SECRET=
GATEWAY_INTERNAL_SECRET=
ENCRYPTION_KEY=
SESSION_SECRET=

# -------------------------------
# Bootstrap users (required)
# -------------------------------
# NOTE: current schema supports roles: customer, provider, admin.
# SUPER_ADMIN is created as an admin-role user.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# -------------------------------
# PostgreSQL
# -------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=marketplace

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_NAME=marketplace
DATABASE_URL=postgresql://postgres:REPLACE_ME@postgres:5432/marketplace
DATABASE_SSL=false

# -------------------------------
# Redis
# -------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# -------------------------------
# Worker-level feature flags
# -------------------------------
CACHE_ENABLED=true
WORKERS_ENABLED=true
EVENT_BUS_ENABLED=false
BACKGROUND_JOBS_ENABLED=false
RATE_LIMITING_ENABLED=true
FEATURE_FLAGS_ENABLED=true

ANALYTICS_ENABLED=false
INFRASTRUCTURE_ENABLED=false
MESSAGING_ENABLED=false
API_GATEWAY_ENABLED=true

# -------------------------------
# Gateway / frontend wiring
# -------------------------------
API_GATEWAY_PORT=3700
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=https://your-frontend-domain.com
FRONTEND_URL=https://your-frontend-domain.com

# Browser-facing API URL for frontend builds
NEXT_PUBLIC_API_URL=https://api.your-domain.com
INTERNAL_API_URL=http://api-gateway:3000
NEXTAUTH_URL=https://your-frontend-domain.com
AUTH_SECRET=

# -------------------------------
# External services
# -------------------------------
# REQUIRED by deploy script (must be https and non-placeholder)
FILE_UPLOAD_SERVICE_URL=https://your-file-service.example.com
FILE_DEFAULT_TENANT_ID=default

# Optional: external email/sms service endpoints
EMAIL_SERVICE_URL=
SMS_SERVICE_URL=
SMS_API_KEY=

# -------------------------------
# OAuth (optional)
# -------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# -------------------------------
# Performance
# -------------------------------
DB_POOL_MAX=20
DB_POOL_MIN=5
REQUEST_TIMEOUT_MS=72000

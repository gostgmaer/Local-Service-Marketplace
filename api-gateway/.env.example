# ===============================================
# API GATEWAY CONFIGURATION
# ===============================================

# Application
NODE_ENV=development
PORT=3700
SERVICE_NAME=api-gateway

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Gateway Internal Secret (for auth service communication)
GATEWAY_INTERNAL_SECRET=gateway-internal-secret-change-in-production

# Token Validation Strategy
# Options: 'local' (JWT verification in gateway) or 'api' (call auth service)
# 'local' = faster, lower latency, gateway needs JWT_SECRET
# 'api' = centralized, can check user status, auth service dependency
TOKEN_VALIDATION_STRATEGY=local

# Microservice URLs (Merged Services)
# For Docker: Use container names
# For Local: Use localhost with appropriate ports
IDENTITY_SERVICE_URL=http://localhost:3001
MARKETPLACE_SERVICE_URL=http://localhost:3003
PAYMENT_SERVICE_URL=http://localhost:3006
COMMS_SERVICE_URL=http://localhost:3007
OVERSIGHT_SERVICE_URL=http://localhost:3010
INFRASTRUCTURE_SERVICE_URL=http://localhost:3012


# External Services (Deployed Separately)
# File Upload Service - Configure with your deployed file service URL
FILE_UPLOAD_SERVICE_URL=https://your-file-service.vercel.app


# Rate Limiting (per user/IP per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=500

# CORS Configuration
# Comma-separated list of allowed origins (frontend URLs)
# Production example: CORS_ORIGINS=https://lsp.easydev.in,https://easydev.in,https://www.easydev.in
# Local dev (localhost:3000) is always allowed when NODE_ENV=development
CORS_ORIGINS=https://lsp.easydev.in,https://easydev.in,https://www.easydev.in,http://localhost:3000

# Redis Configuration (Optional - for distributed rate limiting across multiple gateway replicas)
# For Docker: Use 'redis' as host. For Local: use 'localhost'.
# Set REDIS_RATE_LIMIT_ENABLED=true to share rate limit counters across multiple gateway replicas.
# Set REDIS_RATE_LIMIT_ENABLED=false for single-instance deployments (uses in-memory counters).
REDIS_RATE_LIMIT_ENABLED=false
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

REQUEST_TIMEOUT_MS=72000
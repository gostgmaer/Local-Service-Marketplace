# ===============================================
# FRONTEND ENVIRONMENT CONFIGURATION
# Local Service Marketplace - Next.js Application
# ===============================================

# -----------------------------------------------
# API Configuration
# -----------------------------------------------

# API Gateway URL (primary endpoint for all backend APIs)
NEXT_PUBLIC_API_URL=http://localhost:3700

# WebSocket URL — defaults to NEXT_PUBLIC_API_GATEWAY_URL or NEXT_PUBLIC_API_URL when omitted.
# Override when the WS endpoint differs from the REST gateway.
# NEXT_PUBLIC_WS_URL=http://localhost:3700

# Additional CSP connect-src origins (space-separated). Used in next.config.js Content-Security-Policy.
# Production example: NEXT_PUBLIC_EXTRA_CONNECT_SRC=https://*.yourdomain.com
NEXT_PUBLIC_EXTRA_CONNECT_SRC=https://*.easydev.in

# Fix HMR file watching on Windows (set to true on Windows dev machines)
WATCHPACK_POLLING=true

# Internal API URL for server-side requests inside Docker (Next.js SSR → api-gateway container)
# Leave empty for local dev (falls back to NEXT_PUBLIC_API_URL)
INTERNAL_API_URL=http://api-gateway:3700

# Request timeout in milliseconds for API calls (default: 72000)
NEXT_PUBLIC_API_TIMEOUT=72000

# Production site URL — used in sitemap.ts, robots.ts, SEO metadata, and structured data
# Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------

# NextAuth Secret - REQUIRED for production
# Generate with: openssl rand -base64 32
# IMPORTANT: Keep this secret and never commit to version control
AUTH_SECRET=your_generated_secret_here_change_in_production

# NextAuth URL - Base URL for authentication callbacks
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------
# OAuth Providers (Optional)
# -----------------------------------------------

# Google OAuth (Optional - for Google Sign-In)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Steps:
# 1. Create a new project or select existing
# 2. Enable Google+ API
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add authorized redirect URI: http://localhost:3000/api/auth/callback/google
# 5. For production, add: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth (Optional - for Facebook Login)
# Get credentials from: https://developers.facebook.com/apps/
# Steps:
# 1. Create a new Facebook App
# 2. Add "Facebook Login" product
# 3. Configure OAuth Redirect URIs:
#    - Development: http://localhost:3000/api/auth/callback/facebook
#    - Production: https://yourdomain.com/api/auth/callback/facebook
# 4. Copy App ID and App Secret
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret

# -----------------------------------------------
# Application Settings
# -----------------------------------------------

# Session max age in days (default: 90). Must match identity-service SESSION_TTL_DAYS.
SESSION_MAX_AGE_DAYS=90

# Access token expiration in minutes. Must match identity-service JWT_EXPIRES_IN (currently 1d = 1440 min).
# Set slightly shorter to refresh before expiry with clock-drift margin.
NEXT_PUBLIC_ACCESS_TOKEN_EXPIRATION_MINS=1380

# -----------------------------------------------
# Feature Flags
# -----------------------------------------------

# Feature flags are now controlled from the admin panel (system_settings table).
# Toggle notifications_enabled, messaging_enabled, etc. via Admin > Settings
# at runtime — no rebuild required.

# Web Vitals reporting endpoint (optional, leave empty to disable)
NEXT_PUBLIC_ANALYTICS_ENDPOINT=

# -----------------------------------------------
# Social Media URLs (optional)
# -----------------------------------------------

# Footer social links — leave empty to fallback to /contact page
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=

# -----------------------------------------------
# Third-Party Integrations
# -----------------------------------------------

# Google Maps API Key (for location features)
# Get your key from: https://console.cloud.google.com/google/maps-apis
# Required for: LocationPicker component, provider search by location
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Analytics Tracking ID (optional)
# Get your ID from: https://analytics.google.com/
# Format: G-XXXXXXXXXX (GA4) or UA-XXXXXXXXX-X (Universal Analytics)
# Leave empty to disable Google Analytics
NEXT_PUBLIC_GA_ID=

# -----------------------------------------------
# Environment
# -----------------------------------------------

NODE_ENV=development

# -----------------------------------------------
# Internal API Routes (Not Recommended)
# -----------------------------------------------

# PAYMENT_SERVICE_URL - Direct payment service URL
# WARNING: Should use NEXT_PUBLIC_API_URL instead via API Gateway
# Only override if you need direct payment service access (not recommended)
# PAYMENT_SERVICE_URL=http://localhost:3006

# -----------------------------------------------
# Build Configuration (Optional)
# -----------------------------------------------

# NEXT_PUBLIC_VERCEL_URL - Auto-set by Vercel deployment
# NEXT_PUBLIC_SITE_URL - Public site URL for SEO, Open Graph, etc.

# -----------------------------------------------
# Feature Flags (Future Use)
# -----------------------------------------------

# NEXT_PUBLIC_ENABLE_MESSAGING=false
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
# NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=false
NEXT_PUBLIC_API_TIMEOUT=72000